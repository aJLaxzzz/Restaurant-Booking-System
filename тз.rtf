\'a0\'a0\'a0 payment := INSERT INTO payments (reservation_id, amount, status='pending')\
\'a0\'a0\'a0 tx.Commit()\
\'a0\'a0\'a0 \
\'a0\'a0\'a0 // 5. \uc0\u1043 \u1077 \u1085 \u1077 \u1088 \u1072 \u1094 \u1080 \u1103  \u1089 \u1089 \u1099 \u1083 \u1082 \u1080  \u1085 \u1072  \u1086 \u1087 \u1083 \u1072 \u1090 \u1091 \

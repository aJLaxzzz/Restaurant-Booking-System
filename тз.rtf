\'a0 const [lastMessage, setLastMessage] = useState<MessageEvent | null>(null);\
\'a0 const ws = useRef<WebSocket | null>(null);\
\'a0\
\'a0 useEffect(() => \{\
\'a0\'a0\'a0 const connect = () => \{\

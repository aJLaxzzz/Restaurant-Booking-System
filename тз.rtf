\'a0\'a0\'a0\'a0\'a0 \};\
\'a0\'a0\'a0\'a0\'a0 \
\'a0\'a0\'a0\'a0\'a0 ws.current.onerror = (error) => console.error('WebSocket error:', error);\
\'a0\'a0\'a0\'a0\'a0 \
\'a0\'a0\'a0\'a0\'a0 ws.current.onclose = () => \{\

\'a0\
\'a0 useEffect(() => \{\
\'a0\'a0\'a0 // \uc0\u1054 \u1073 \u1088 \u1072 \u1073 \u1086 \u1090 \u1082 \u1072  WebSocket \u1089 \u1086 \u1073 \u1099 \u1090 \u1080 \u1081 \
\'a0\'a0\'a0 if (lastMessage) \{\
\'a0\'a0\'a0\'a0\'a0 const msg = JSON.parse(lastMessage.data);\
\'a0\'a0\'a0\'a0\'a0 if (msg.event === 'table.status_changed') \{\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 setTables(prev => prev.map(t => \
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 t.id === msg.table_id ? \{ ...t, status: msg.status \} : t\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 ));\
\'a0\'a0\'a0\'a0\'a0 \}\
\'a0\'a0\'a0 \}\
\'a0 \}, [lastMessage]);\
\'a0\
\'a0 const handleTableClick = (tableId: string) => \{\
\'a0\'a0\'a0 if (!isAdmin) \{\
\'a0\'a0\'a0\'a0\'a0 setSelectedTableId(tableId);\
\'a0\'a0\'a0\'a0\'a0 // \uc0\u1054 \u1090 \u1082 \u1088 \u1099 \u1090 \u1100  \u1084 \u1086 \u1076 \u1072 \u1083 \u1082 \u1091  \u1073 \u1088 \u1086 \u1085 \u1080 \u1088 \u1086 \u1074 \u1072 \u1085 \u1080 \u1103 \
\'a0\'a0\'a0 \}\
\'a0 \};\
\'a0\
\'a0 const handleTableDragEnd = (e: any, tableId: string) => \{\
\'a0\'a0\'a0 if (isAdmin) \{\
\'a0\'a0\'a0\'a0\'a0 const newX = e.target.x();\
\'a0\'a0\'a0\'a0\'a0 const newY = e.target.y();\
\'a0\'a0\'a0\'a0\'a0 // \uc0\u1054 \u1090 \u1087 \u1088 \u1072 \u1074 \u1082 \u1072  \u1085 \u1072  \u1089 \u1077 \u1088 \u1074 \u1077 \u1088 \
\'a0\'a0\'a0\'a0\'a0 fetch(`/api/halls/$\{hallId\}/tables/$\{tableId\}`, \{\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 method: 'PUT',\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 body: JSON.stringify(\{ x: newX, y: newY \})\

\'a0\'a0\'a0\'a0\'a0\'a0\'a0 setTimeout(connect, 2000); // \uc0\u1040 \u1074 \u1090 \u1086 -\u1088 \u1077 \u1082 \u1086 \u1085 \u1085 \u1077 \u1082 \u1090 \
\'a0\'a0\'a0\'a0\'a0 \};\
\'a0\'a0\'a0 \};\
\'a0\'a0\'a0 \
\'a0\'a0\'a0 connect();\
\'a0\'a0\'a0 \
\'a0\'a0\'a0 return () => \{\
\'a0\'a0\'a0\'a0\'a0 ws.current?.close();\
\'a0\'a0\'a0 \};\
\'a0 \}, [url]);\
\'a0\
\'a0 const sendMessage = (data: any) => \{\
\'a0\'a0\'a0 if (ws.current?.readyState === WebSocket.OPEN) \{\
\'a0\'a0\'a0\'a0\'a0 ws.current.send(JSON.stringify(data));\
\'a0\'a0\'a0 \}\
\'a0 \};\
\'a0\
\'a0 return \{ lastMessage, sendMessage \};\
\};\

\'a0\'a0\'a0\'a0\'a0 case 'occupied': return '#F44336';\
\'a0\'a0\'a0\'a0\'a0 case 'blocked': return '#9E9E9E';\
\'a0\'a0\'a0\'a0\'a0 case 'selected': return '#2196F3';\
\'a0\'a0\'a0\'a0\'a0 default: return '#FFC107';\
\'a0\'a0\'a0 \}\
\'a0 \};\
\'a0\
\'a0 return (\
\'a0\'a0\'a0 <Stage width=\{800\} height=\{600\}>\
\'a0\'a0\'a0\'a0\'a0 <Layer>\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 \{tables.map(table => (\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 table.shape === 'circle' ? (\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 <Circle\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 key=\{table.id\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 x=\{table.x\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 y=\{table.y\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 radius=\{30\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 fill=\{getTableColor(table.status)\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 stroke=\{selectedTableId === table.id ? '#000' : undefined\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 strokeWidth=\{selectedTableId === table.id ? 3 : 0\}\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 draggable=\{isAdmin\}\

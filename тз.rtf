\'a0\'a0\'a0\'a0\'a0\'a0\'a0 SELECT id FROM reservations \
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 WHERE table_id = $1 \
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 AND status NOT IN ('cancelled_by_client', 'cancelled_by_admin', 'no_show')\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 AND (\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 (start_time <= $2 AND end_time > $2) OR\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 (start_time < $3 AND end_time >= $3) OR\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0\'a0 (start_time >= $2 AND end_time <= $3)\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 )\
\'a0\'a0\'a0 `\
\'a0\'a0\'a0 if conflict exists \{\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 return error "Table is already booked for this time"\
\'a0\'a0\'a0 \}\
\'a0\'a0\'a0 \
\'a0\'a0\'a0 // 3. \uc0\u1042 \u1088 \u1077 \u1084 \u1077 \u1085 \u1085 \u1072 \u1103  \u1073 \u1083 \u1086 \u1082 \u1080 \u1088 \u1086 \u1074 \u1082 \u1072  \u1074  Redis\
\'a0\'a0\'a0 lockKey := fmt.Sprintf("table:%s:lock", tableID)\
\'a0\'a0\'a0 success := redis.SetNX(lockKey, userID, 5*time.Minute)\
\'a0\'a0\'a0 if !success \{\
\'a0\'a0\'a0\'a0\'a0\'a0\'a0 return error "Table is being booked by another user"\

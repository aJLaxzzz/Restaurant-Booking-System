\'a0 const [tables, setTables] = useState<Table[]>([]);\
\'a0 const [selectedTableId, setSelectedTableId] = useState<string | null>(null);\
\'a0 \
\'a0 const \{ lastMessage \} = useWebSocket(`wss://api.domain.com/ws/halls/$\{hallId\}`);\
\'a0\
\'a0 useEffect(() => \{\
\'a0\'a0\'a0 // \uc0\u1047 \u1072 \u1075 \u1088 \u1091 \u1079 \u1082 \u1072  \u1085 \u1072 \u1095 \u1072 \u1083 \u1100 \u1085 \u1099 \u1093  \u1076 \u1072 \u1085 \u1085 \u1099 \u1093 \
\'a0\'a0\'a0 fetch(`/api/halls/$\{hallId\}/layout`)\
